---
import { FOOTER_INFO, SECTION_IDS, SITE_BRAND } from "../../../data/site";
---

<div class="lg:col-span-1 flex flex-col items-start">
    <a
        href={`#${SECTION_IDS.home}`}
        class="group mb-6 flex items-center gap-3 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
    >
        <div class="rounded-xl bg-surface p-2 transition-transform group-hover:scale-105">
            <img
                src={SITE_BRAND.logo.src}
                alt={SITE_BRAND.logo.alt}
                loading="lazy"
                class="h-12 w-auto object-contain"
            />
        </div>
        <div class="flex flex-col">
            <span
                class="text-xl font-black font-heading uppercase tracking-[0.08em] text-white leading-none"
            >
                {SITE_BRAND.name}
            </span>
            <span class="mt-1.5 text-[10px] font-heading font-black uppercase tracking-[0.18em] text-primary">
                {SITE_BRAND.subtitle}
            </span>
        </div>
    </a>
    <p class="text-slate-400 text-sm leading-relaxed mb-6">
        {FOOTER_INFO.brandDescription}
    </p>
</div>
