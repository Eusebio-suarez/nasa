---
import Button from "../ui/Button.astro";
import { NAVIGATION, SECTION_IDS, SITE_BRAND } from "../../data/site";
---

<nav
    class="sticky top-0 z-50 flex h-20 items-center justify-between border-b border-border/70 bg-surface/85 px-6 backdrop-blur-md md:px-12"
>
    <a
        href={`#${SECTION_IDS.home}`}
        class="group flex items-center gap-3 rounded-lg p-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
    >
        <img
            src={SITE_BRAND.logo.src}
            alt={SITE_BRAND.logo.alt}
            class="h-12 w-auto object-contain transition-transform group-hover:scale-105"
        />
        <div class="flex flex-col">
            <span
                class="font-heading text-xl font-black leading-none tracking-tight text-primary"
                >{SITE_BRAND.name}
            </span>
            <span
                class="mt-0.5 text-[10px] font-medium italic tracking-normal text-secondary"
                >{SITE_BRAND.subtitle}
            </span>
        </div>
    </a>
    <div
        class="hidden items-center gap-8 text-sm font-medium text-text md:flex"
    >
        {
            NAVIGATION.items.map((link) => (
                <a
                    href={link.href}
                    aria-label={link.ariaLabel}
                    class="nav-link rounded-md px-2 py-1 transition-colors hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
                >
                    {link.label}
                </a>
            ))
        }
    </div>
    <div class="hidden sm:block">
        <Button
            variant="primary"
            size="sm"
            href={NAVIGATION.cta.href}
            ariaLabel={NAVIGATION.cta.ariaLabel}
            target={NAVIGATION.cta.target}
            rel={NAVIGATION.cta.rel}
        >
            {NAVIGATION.cta.label}
        </Button>
    </div>
</nav>

<script>
    const setupActiveLinks = () => {
        const sections = document.querySelectorAll("section[id]");
        const navLinks = document.querySelectorAll("a.nav-link");

        const observerOptions = {
            root: null,
            rootMargin: "-30% 0px -70% 0px",
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    navLinks.forEach((link) => {
                        const targetId = link.getAttribute("href");
                        if (targetId === `#${entry.target.id}`) {
                            // Link Activo
                            link.classList.add(
                                "text-secondary",
                                "font-extrabold",
                                "scale-105"
                            );
                        } else {
                            // Link Inactivo
                            link.classList.remove(
                                "text-secondary",
                                "font-extrabold",
                                "scale-105"
                            );
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach((section) => observer.observe(section));
    };

    document.addEventListener("DOMContentLoaded", setupActiveLinks);
    // Compatibilidad en caso de usar ViewTransitions
    document.addEventListener("astro:page-load", setupActiveLinks);
</script>
