---
import SectionBadge from "../../ui/SectionBadge.astro";
import AboutHighlights from "./AboutHighlights.astro";
import { ABOUT_SECTION } from "../../../data/site";
---

<div class="reveal reveal-right">
    <SectionBadge label={ABOUT_SECTION.badge} class="mb-8" />
    <h2
        class="mb-8 text-balance font-heading text-4xl font-bold leading-tight text-secondary md:text-5xl"
    >
        {ABOUT_SECTION.title}
    </h2>
    <p class="mb-10 text-lg leading-relaxed text-text">
        {ABOUT_SECTION.description}
    </p>

    <AboutHighlights />
</div>
