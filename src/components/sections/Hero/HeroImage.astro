---
import { HERO_SECTION } from "../../../data/site";
---

<div
    class="relative w-full max-w-[28rem] sm:max-w-[32rem] lg:max-w-[30rem] xl:max-w-[32rem] mx-auto lg:mx-0 lg:justify-self-end lg:h-[550px]  fade-in-scale"
>
    <!-- Main Image Container -->
    <div
        class="relative h-full w-full overflow-hidden rounded-[3rem] border-8 border-white shadow-2xl shadow-secondary/15"
    >
        <img
            src={HERO_SECTION.image.src}
            alt={HERO_SECTION.image.alt}
            fetchpriority="high"
            class="w-full h-full object-cover"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-secondary/20 to-transparent"
        >
        </div>
    </div>

    <!-- Decorative Dots -->
    <div
        class="absolute -bottom-10 -left-10 grid grid-cols-6 gap-3 -z-10 opacity-20"
    >
        {
            Array.from({ length: 24 }).map((_, i) => (
                <div class="h-2 w-2 rounded-full bg-primary" />
            ))
        }
    </div>
</div>

<style>
    .fade-in-scale {
        opacity: 0;
        animation: fadeInScale 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }

    @keyframes fadeInScale {
        from {
            opacity: 0;
            transform: scale(0.95) translateX(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateX(0);
        }
    }
</style>
