---
import Button from "../../ui/Button.astro";
import Icon from "../../ui/Icon.astro";
import SectionBadge from "../../ui/SectionBadge.astro";
import { FEATURE_SECTION } from "../../../data/site";
---

<div class="relative overflow-hidden reveal">
    <div
        class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-primary/8 blur-[80px]"
    >
    </div>
    <div
        class="pointer-events-none absolute -bottom-24 -left-24 h-80 w-80 rounded-full bg-secondary/8 blur-[80px]"
    >
    </div>

    <div
        class="relative z-10 overflow-hidden rounded-[2.5rem] border border-border/60 bg-gradient-to-br from-page to-surface shadow-xl shadow-slate-200/60"
    >
        <div
            class="h-1 w-full bg-gradient-to-r from-primary via-secondary to-accent"
        >
        </div>

        <div class="grid items-stretch gap-0 lg:grid-cols-2">
            <div class="flex flex-col justify-center p-10 md:p-14">
                <SectionBadge
                    label={FEATURE_SECTION.badge}
                    icon="sparkles"
                    class="mb-8 w-fit"
                />

                <h3
                    class="mb-6 text-balance font-heading text-4xl font-black uppercase leading-[0.9] tracking-[0.05em] text-secondary md:text-5xl"
                >
                    {FEATURE_SECTION.title}
                </h3>

                <p class="mb-10 text-lg leading-relaxed text-text">
                    {FEATURE_SECTION.description}
                </p>

                <ul class="mb-10 space-y-5">
                    {
                        FEATURE_SECTION.benefits.map((benefit) => (
                            <li class="flex items-start gap-4">
                                <div class="mt-0.5 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl bg-secondary/10 text-secondary">
                                    <Icon name={benefit.icon} size={18} />
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-slate-800">
                                        {benefit.title}
                                    </p>
                                    <p class="text-sm leading-relaxed text-slate-500">
                                        {benefit.description}
                                    </p>
                                </div>
                            </li>
                        ))
                    }
                </ul>

                <div class="flex flex-col gap-4 sm:flex-row">
                    <Button
                        variant="primary"
                        href={FEATURE_SECTION.primaryAction.href}
                        ariaLabel={FEATURE_SECTION.primaryAction.ariaLabel}
                        target={FEATURE_SECTION.primaryAction.target}
                        rel={FEATURE_SECTION.primaryAction.rel}
                    >
                        {FEATURE_SECTION.primaryAction.label}
                        <Icon
                            name="chevron-right"
                            size={18}
                            class="transition-transform group-hover:translate-x-1"
                        />
                    </Button>
                </div>
            </div>

            <div class="relative min-h-[420px] lg:min-h-0">
                <img
                    src={FEATURE_SECTION.image.src}
                    alt={FEATURE_SECTION.image.alt}
                    class="absolute inset-0 h-full w-full object-cover"
                    loading="lazy"
                />
                <div
                    class="pointer-events-none absolute inset-y-0 left-0 hidden w-24 bg-gradient-to-r from-page to-transparent lg:block"
                >
                </div>
                {
                    FEATURE_SECTION.secondaryCard && (
                        <div
                            class="absolute bottom-6 left-6 right-6 rounded-2xl border border-white/60 bg-white/90 p-4 shadow-xl backdrop-blur-sm lg:left-auto lg:right-6 lg:max-w-[220px]"
                        >
                            <div class="flex items-center gap-3">
                                <div
                                    class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary"
                                >
                                    <Icon
                                        name={FEATURE_SECTION.secondaryCard.icon}
                                        size={18}
                                    />
                                </div>
                                <div>
                                    <p
                                        class="text-sm font-bold leading-tight text-slate-800"
                                    >
                                        {FEATURE_SECTION.secondaryCard.title}
                                    </p>
                                    <p class="mt-0.5 text-xs text-slate-500">
                                        {FEATURE_SECTION.secondaryCard.description}
                                    </p>
                                </div>
                            </div>
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</div>
