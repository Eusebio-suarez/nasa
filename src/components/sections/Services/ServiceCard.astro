---
import Icon from "../../ui/Icon.astro";
import { SERVICES_SECTION } from "../../../data/site";
import type { ServiceItemConfig } from "../../../types/site";

interface Props {
    service: ServiceItemConfig;
}

const { service } = Astro.props;
const action = SERVICES_SECTION.resolveItemAction(service.title);
---

<div
    class="bg-white rounded-[2rem] overflow-hidden border border-slate-100 shadow-xl shadow-slate-200/50 h-full flex flex-col group transition-transform duration-300 hover:-translate-y-2"
>
    <div class="relative h-64 overflow-hidden">
        <img
            src={service.image.src}
            alt={service.image.alt}
            width="960"
            height="640"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        />
    </div>
    <div class="p-8 flex-grow flex flex-col">
        <h3
            class="mb-3 font-heading text-xl font-bold text-secondary transition-colors"
        >
            {service.title}
        </h3>
        <p class="text-slate-500 text-sm leading-relaxed mb-6 flex-grow">
            {service.description}
        </p>
        <a
            href={action.href}
            target={action.target}
            rel={action.rel}
            aria-label={action.ariaLabel}
            class="inline-flex self-start gap-2 rounded-full px-5 py-3 text-sm font-bold text-primary transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary/90 hover:text-white hover:shadow-lg hover:shadow-primary/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
        >
            {action.label}
            <Icon
                name="chevron-right"
                size={16}
                class="transition-transform duration-300"
            />
        </a>
    </div>
</div>
