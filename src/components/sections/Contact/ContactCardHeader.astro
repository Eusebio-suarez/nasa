---
import { CONTACT_SECTION, SITE_BRAND } from "../../../data/site";
---

<div class="flex flex-col items-center mb-10 gap-3">
    <img
        src={SITE_BRAND.logo.src}
        alt={SITE_BRAND.logo.alt}
        width="384"
        height="192"
        loading="lazy"
        decoding="async"
        class="h-24 w-auto object-contain"
    />
</div>

<div class="text-center mb-10">
    <p class="mb-3 font-heading text-[11px] font-black uppercase tracking-[0.18em] text-secondary">
        {CONTACT_SECTION.card.eyebrow}
    </p>
    <p class="text-slate-500 leading-relaxed mb-4">
        {CONTACT_SECTION.card.description}
    </p>
    {
        CONTACT_SECTION.card.supportingText && (
            <p class="mb-4 leading-relaxed text-slate-500">
                {CONTACT_SECTION.card.supportingText}
            </p>
        )
    }
    <p class="text-slate-800 font-bold text-lg">{CONTACT_SECTION.card.closingText}</p>
</div>
