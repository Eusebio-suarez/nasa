---
import Icon from "../../ui/Icon.astro";
import ContactCardHeader from "./ContactCardHeader.astro";
import ContactInfoList from "./ContactInfoList.astro";
---

<div
    class="bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 overflow-hidden relative reveal reveal-left"
>
    <div class="p-10 md:p-12">
        <ContactCardHeader />
        <ContactInfoList />
    </div>

    <div class="absolute bottom-0 right-0 p-4 opacity-5 pointer-events-none">
        <Icon name="whatsapp" size={120} class="text-secondary" />
    </div>
</div>
