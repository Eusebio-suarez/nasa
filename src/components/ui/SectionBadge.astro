---
import Icon from "./Icon.astro";
import type { IconName } from "../../types/site";

interface Props {
    label: string;
    icon?: IconName;
    class?: string;
}

const { label, icon = "sparkles", class: className = "" } = Astro.props;
---

<div
    class:list={[
        "inline-flex items-center gap-2 rounded-md border border-primary/20 bg-surface/95 px-4 py-2 text-[11px] font-heading font-black uppercase tracking-[0.24em] text-primary shadow-sm shadow-primary/5",
        className,
    ]}
>
    <Icon name={icon} size={14} class="shrink-0" />
    {label}
</div>
