---
import type { IconName } from "../../types/site";
import WhatsAppBrandIcon from "./WhatsAppBrandIcon.astro";

interface Props {
    name: IconName;
    size?: number | string;
    class?: string;
    strokeWidth?: number | string;
}

const {
    name,
    size = 24,
    class: className = "",
    strokeWidth = 2,
} = Astro.props;
---

{
    name === "chevron-left" && (
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width={size}
            height={size}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width={strokeWidth}
            stroke-linecap="round"
            stroke-linejoin="round"
            class={className}
            aria-hidden="true"
        >
            <path d="m15 18-6-6 6-6"></path>
        </svg>
    )
}

{
    name === "chevron-right" && (
        <svg
            xmlns="http://www.w3.org/2000/svg"
