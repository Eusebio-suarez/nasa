---
import "../styles/global.css";
import {
	FONT_STYLESHEET_URL,
	SITE_LANGUAGE,
	THEME_STYLE_VARS,
} from "../data/site";
import Navbar from "../components/layout/Navbar.astro";
import Hero from "../components/sections/Hero/Hero.astro";
import About from "../components/sections/About.astro";
import Services from "../components/sections/Services.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/layout/Footer.astro";
import FloatingActionButton from "../components/ui/FloatingActionButton.astro";
import SEO from "../components/layout/SEO.astro";
---

<html lang={SITE_LANGUAGE} style={THEME_STYLE_VARS}>
	<head>
		<SEO />

		{
			FONT_STYLESHEET_URL && (
				<>
					<link rel="preconnect" href="https://fonts.googleapis.com" />
					<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
					<link href={FONT_STYLESHEET_URL} rel="stylesheet" />
				</>
			)
		}
	</head>
	<body
		class="flex min-h-screen flex-col bg-page font-sans text-text antialiased selection:bg-primary/20 selection:text-secondary"
	>
		<Navbar />
		<Hero />
		<About />
		<Services />
		<Contact />
		<Footer />
		<FloatingActionButton />
	</body>
</html>
